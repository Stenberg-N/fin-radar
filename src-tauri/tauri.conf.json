{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FinRadar",
  "version": "0.1.0",
  "identifier": "com.stenberg.fin-radar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "FinRadar",
        "width": 1700,
        "height": 1000,
        "minHeight": 760,
        "minWidth": 960
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
